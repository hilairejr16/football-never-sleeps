# ============================================================
# GOALRUSH GLOBAL — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the real .env to git.
# Set production values in Vercel (frontend) and Railway (API).
# ============================================================
#
# ⚠ SECURITY CHECKLIST — run after any credential exposure:
#   [ ] Anthropic Console → API Keys → delete old → create new
#   [ ] API-Football → Dashboard → Regenerate key
#   [ ] Twitter Dev Portal → App → Keys & Tokens → Regenerate
#   [ ] Railway → Project → Variables → rotate DATABASE_URL & REDIS_URL
#   [ ] GitHub → Settings → Security → Review secret scanning alerts
#   [ ] Regenerate JWT_SECRET + JWT_REFRESH_SECRET (see command below)
#   [ ] Update ADMIN_PASSWORD to a strong new value
#
# Generate new JWT secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://www.goalrushglobal.com
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
AI_ENGINE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/goalrush
REDIS_URL=redis://localhost:6379

# Football APIs
FOOTBALL_API_KEY=your_api_football_key         # api-football.com — primary (WC 2026, all leagues, live scores)
RAPID_API_KEY=your_rapid_api_key               # only needed if billing through RapidAPI instead of api-sports.io directly
FOOTBALL_DATA_API_KEY=your_football_data_key   # football-data.org — free secondary (10 major leagues, standings, scorers)
SOFASCORE_API_KEY=your_sofascore_key

# News APIs
NEWS_API_KEY=your_newsapi_key                  # newsapi.org — supplements RSS aggregator with 20 extra articles/fetch

# AI Services
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
ELEVENLABS_API_KEY=your_elevenlabs_key
STABILITY_AI_KEY=your_stability_key

# Social Media — TikTok
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# Social Media — Instagram / Meta
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# Social Media — X (Twitter)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Social Media — YouTube
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# Social Media — Facebook
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=your_telegram_channel_id

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Authentication — ROTATE all of these; they were previously exposed
JWT_SECRET=REPLACE_WITH_NEW_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_NEW_64_BYTE_HEX_SECRET
ADMIN_EMAIL=admin@goalrushglobal.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Monetization
ADSENSE_PUBLISHER_ID=pub-xxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_PREMIUM=price_xxxx

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
FROM_EMAIL=noreply@goalrushglobal.com

# Storage
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=goalrush-media

# CDN
CLOUDFLARE_ZONE_ID=your_cf_zone_id
CLOUDFLARE_API_TOKEN=your_cf_api_token

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your_mixpanel_token

# Video Generation
CREATOMATE_API_KEY=your_creatomate_key
RUNWAY_API_KEY=your_runway_key
