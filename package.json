{
  "name": "goalrush-global",
  "version": "1.0.0",
  "description": "Football Never Sleeps — Global Automated Football Media Empire",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "automation"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:migrate": "node packages/database/migrate.js",
    "db:seed": "node packages/database/seed.js",
    "automation:start": "node automation/cron/scheduler.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
